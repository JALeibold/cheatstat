# ===============================================================
# simpleStat – .gitignore
# ===============================================================

# ---------------------------------------------------------------
# SSH-Keys (NIEMALS hochladen!)
# ---------------------------------------------------------------
*.pem
*ssh-key*
id_rsa*
id_ed25519*
*.ppk

# ---------------------------------------------------------------
# Python
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / Packaging
.eggs/
*.egg-info/
*.egg
dist/
build/
wheels/
sdist/
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------
# Virtuelle Umgebungen
# ---------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/
conda-env/

# ---------------------------------------------------------------
# Jupyter Notebook
# ---------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ---------------------------------------------------------------
# Editor-Backup-Dateien
# ---------------------------------------------------------------
*~
*.md~
*.py~
*.bak
*.swp
*.swo
*#
.#*

# ---------------------------------------------------------------
# Betriebssystem
# ---------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ---------------------------------------------------------------
# IDEs und Editoren
# ---------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Spyder
.spyderproject.db
.spyproject/

# Jupyter
.jupyter/

# ---------------------------------------------------------------
# Tests und Coverage
# ---------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
*.cover
*.py,cover
.tox/
.nox/

# ---------------------------------------------------------------
# Dokumentations-Build
# ---------------------------------------------------------------
docs/_build/
docs/_autosummary/
site/
.mkdocs/

# ---------------------------------------------------------------
# Temporäre Dateien
# ---------------------------------------------------------------
*.tmp
*.temp
*.log
*.cache
.cache/

# ---------------------------------------------------------------
# Daten (ALLBUS und andere sensitive Daten)
# ---------------------------------------------------------------
*.sav
*.dta
*.por
*.sas7bdat
*.zsav
data/
raw_data/

# ---------------------------------------------------------------
# PyPI / Build
# ---------------------------------------------------------------
.python-version
poetry.lock
Pipfile.lock

# ---------------------------------------------------------------
# mypy / Typprüfung
# ---------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------
# Sonstiges
# ---------------------------------------------------------------
*.orig
*.rej
.env
.env.*
secrets.py
local_settings.py